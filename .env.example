# Beacon environment variables
# Copy this file to .env and fill in your credentials
# .env is in .gitignore — never commit this file

# LLM Provider — supported: anthropic, openai, google
LLM_PROVIDER=anthropic

# Anthropic (default)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (if LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Google Gemini (if LLM_PROVIDER=google)
GOOGLE_API_KEY=...
GOOGLE_MODEL=gemini-1.5-pro

# Slack credentials (from api.slack.com/apps)
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_APP_TOKEN=xapp-your-app-token-here

# Slack channel IDs
# Right-click the channel in Slack → View channel details → copy ID at the bottom
ASK_BEACON_CHANNEL_ID=C...
BEACON_GAPS_CHANNEL_ID=C...

# Link to your enablement materials (Notion, Confluence, Google Drive, etc.)
ENABLEMENT_URL=https://...

# Notion gap logging (optional)
# Only needed if you want unanswered questions logged to a Notion database
NOTION_API_KEY=secret_...
NOTION_DATABASE_ID=...

# GitHub token (optional — only needed for private repos in ingest.py)
# GITHUB_TOKEN=ghp_your-token-here